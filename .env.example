# Gemini API Key
GEMINI_API_KEY=

# Resend API Key for sending emails (Required to actually send emails)
VITE_RESEND_API_KEY=

# Verified sender email address required for Resend when sending to non-testing emails
EMAIL_FROM=
VITE_EMAIL_FROM=

# Optional Studio customization applied to emails
VITE_STUDIO_NAME=
VITE_STUDIO_PHONE=
VITE_STUDIO_LOGO_URL=
VITE_BRAND_COLOR=

# Custom URL domain for signoff review links (defaults to the app URL)
VITE_APP_DOMAIN=
